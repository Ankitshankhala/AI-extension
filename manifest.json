{
  "manifest_version": 3,
  "name": "AI Browser Automation",
  "version": "0.1.0",
  "description": "AI-powered Chrome extension for smart page analysis, automation, and chat.",
  "action": {
    "default_title": "AI Automation",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "history",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "chunks/*.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}

